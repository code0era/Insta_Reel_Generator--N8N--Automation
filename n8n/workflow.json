                ]
            ]
        },
        "Generate Narration (TTS)": {
            "main": [
                [
                    {
                        "node": "Create 30s Video (FFmpeg)",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Create 30s Video (FFmpeg)": {
            "main": [
                [
                    {
                        "node": "Post to Instagram",
